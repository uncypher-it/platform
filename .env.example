# =============================================================================
# Uncypher Self-Hosted Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Required values are marked — the stack will not start without them.

# -----------------------------------------------------------------------------
# Domains (required) — Traefik routes traffic based on these
# -----------------------------------------------------------------------------
FRONTEND_DOMAIN=uncypher.example.com
API_DOMAIN=api.uncypher.example.com
KB_DOMAIN=kb.uncypher.example.com
CODEBASE_DOMAIN=codebase.uncypher.example.com

# URLs passed to frontend and backend services
FRONTEND_URL=https://uncypher.example.com
NEXT_PUBLIC_API_URL=https://api.uncypher.example.com
NEXT_PUBLIC_KBV1_URL=https://kb.uncypher.example.com
CORS_ALLOWED_ORIGINS=https://uncypher.example.com,https://api.uncypher.example.com,https://kb.uncypher.example.com

# -----------------------------------------------------------------------------
# TLS
# -----------------------------------------------------------------------------
# "letsencrypt" for automatic ACME certs (default)
# Leave empty and place certs in ./certs/ for static certs
TLS_CERT_RESOLVER=letsencrypt
ACME_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Databases (required)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

KB_POSTGRES_USER=kb
KB_POSTGRES_PASSWORD=CHANGE_ME

# Redis (leave empty to disable auth)
REDIS_PASSWORD=
REDIS_MAXMEMORY=256mb

# -----------------------------------------------------------------------------
# Authentication (required)
# -----------------------------------------------------------------------------
# Auto-generated by setup.sh if left as CHANGE_ME
JWT_SECRET_KEY=CHANGE_ME
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=3000

# -----------------------------------------------------------------------------
# AI Provider (required)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_AGENT_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# GitHub OAuth (optional)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Codebase Agent
# -----------------------------------------------------------------------------
# Which agent to use by default: "claude" or "codex"
DEFAULT_CODEBASE_AGENT=claude

# Option 1: API keys (set one or both)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY is already set above for chat — Codex reuses it

# Option 2: OAuth login
# Run `claude login` on the host, then run the claude-auth-refresh systemd
# service to keep the claude_credentials Docker volume in sync.

# -----------------------------------------------------------------------------
# Security & Operations
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# Traefik ports (change if 80/443 are taken)
# TRAEFIK_HTTP_PORT=80
# TRAEFIK_HTTPS_PORT=443

# Rate limiting (requests per second)
# RATE_LIMIT_AVERAGE=100
# RATE_LIMIT_BURST=200

# IP allowlist (CIDR notation, comma-separated. Default: allow all)
# ALLOWED_IP_RANGES=0.0.0.0/0

# -----------------------------------------------------------------------------
# Image tag (optional)
# -----------------------------------------------------------------------------
# Override the tag suffix appended to every siddhsingh/uncypher:* image.
# If unset, the compose default tag is used (matches the SuperK ARM build the
# repo is currently pinned to). Override per deployment:
#   TAG_SUFFIX=-12may-x86   # x86_64 build dated 12 May
#   TAG_SUFFIX=-21apr-arm   # newer ARM build
# TAG_SUFFIX=
